function UpdateStockDisplay()
    local normal, advance = GetFruitStock()
    local resetTime = GetResetTime()
    
    if CheckStockChanged(NormalStock, normal) or CheckStockChanged(AdvanceStock, advance) then
        if os.time() - ResetAnimationCooldown > 30 then
            ResetAnimationCooldown = os.time()
            task.spawn(PlayResetAnimation)
        end
    end
    
    NormalStock = normal
    AdvanceStock = advance
    
    for _, child in pairs(Scroller:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    
    local order = 0
    
    local h1 = CreateHeader("Normal Shop", resetTime.Normal, order)
    order = order + 1
    
    if #normal > 0 then
        for _, fruit in ipairs(normal) do
            CreateFruitRow(fruit.Name, fruit.Price, order)
            order = order + 1
        end
    else
        CreateEmptyRow("No stock", order)
        order = order + 1
    end
    
    local div = CreateDivider(order)
    order = order + 1
    
    local h2 = CreateHeader("Mystic Shop", resetTime.Advance, order)
    order = order + 1
    
    if #advance > 0 then
        for _, fruit in ipairs(advance) do
            CreateFruitRow(fruit.Name, fruit.Price, order)
            order = order + 1
        end
    else
        CreateEmptyRow("No stock", order)
        order = order + 1
    end
    
    Scroller.CanvasSize = UDim2.new(0, 0, 0, order * 22 + 10)
end

