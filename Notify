function GetFruitStock()
    local normal = {}
    local advance = {}
    
    local success1, normalFruits = pcall(function()
        return ReplicatedStorage.Remotes.CommF_:InvokeServer("GetFruits")
    end)
    
    if success1 and normalFruits then
        for _, fruit in pairs(normalFruits) do
            if fruit.OnSale then
                table.insert(normal, {
                    Name = fruit.Name,
                    Price = fruit.Price or 0
                })
            end
        end
    end
    
    local success2, advanceFruits = pcall(function()
        return ReplicatedStorage.Remotes.CommF_:InvokeServer("GetFruits", true)
    end)
    
    if success2 and advanceFruits then
        for _, fruit in pairs(advanceFruits) do
            if fruit.OnSale then
                table.insert(advance, {
                    Name = fruit.Name,
                    Price = fruit.Price or 0
                })
            end
        end
    end
    
    return normal, advance
end

function GetResetTime()
    local reset = {Normal = "??:??:??", Advance = "??:??:??"}
    
    local success, data = pcall(function()
        return ReplicatedStorage.Remotes.CommF_:InvokeServer("GetShopResetTime")
    end)
    
    if success and data then
        if type(data) == "number" then
            local remaining = data - os.time()
            if remaining > 0 then
                local timeStr = string.format("%02d:%02d:%02d", 
                    math.floor(remaining / 3600),
                    math.floor((remaining % 3600) / 60),
                    math.floor(remaining % 60)
                )
                reset.Normal = timeStr
                reset.Advance = timeStr
            else
                reset.Normal = "Resetting"
                reset.Advance = "Resetting"
            end
        elseif type(data) == "table" then
            if data.Normal then
                local remaining = data.Normal - os.time()
                if remaining > 0 then
                    reset.Normal = string.format("%02d:%02d:%02d", 
                        math.floor(remaining / 3600),
                        math.floor((remaining % 3600) / 60),
                        math.floor(remaining % 60)
                    )
                else
                    reset.Normal = "Resetting"
                end
            end
            
            if data.Advance then
                local remaining = data.Advance - os.time()
                if remaining > 0 then
                    reset.Advance = string.format("%02d:%02d:%02d", 
                        math.floor(remaining / 3600),
                        math.floor((remaining % 3600) / 60),
                        math.floor(remaining % 60)
                    )
                else
                    reset.Advance = "Resetting"
                end
            end
        end
    else
        local now = os.time()
        local resetHour = 4
        local todayReset = os.time({
            year = os.date("%Y", now),
            month = os.date("%m", now),
            day = os.date("%d", now),
            hour = resetHour,
            min = 0,
            sec = 0
        })
        
        if now > todayReset then
            todayReset = todayReset + 86400
        end
        
        local remaining = todayReset - now
        if remaining > 0 and remaining < 86400 then
            local timeStr = string.format("%02d:%02d:%02d", 
                math.floor(remaining / 3600),
                math.floor((remaining % 3600) / 60),
                math.floor(remaining % 60)
            )
            reset.Normal = timeStr
            reset.Advance = timeStr
        end
    end
    
    return reset
end

function CheckStockChanged(old, new)
    if #old ~= #new then return true end
    for i, fruit in ipairs(new) do
        if not old[i] or old[i].Name ~= fruit.Name or old[i].Price ~= fruit.Price then
            return true
        end
    end
    return false
end

function PlayResetAnimation()
    if ResetAnimationActive then return end
    ResetAnimationActive = true
    
    local flash = Instance.new("Frame")
    flash.Parent = MainFrame
    flash.Size = UDim2.new(1, 0, 1, 0)
    flash.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    flash.BackgroundTransparency = 1
    flash.ZIndex = 10
    flash.BorderSizePixel = 0
    
    local flashCorner = Instance.new("UICorner")
    flashCorner.Parent = flash
    flashCorner.CornerRadius = UDim.new(0, 6)
    
    TweenService:Create(flash, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0.4
    }):Play()
    
    task.wait(0.15)
    
    TweenService:Create(flash, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        BackgroundTransparency = 1
    }):Play()
    
    task.wait(0.3)
    flash:Destroy()
    ResetAnimationActive = false
end

